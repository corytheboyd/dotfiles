#!/usr/bin/env bash
# chezmoi:template:left-delimiter="#{{" right-delimiter=}}

set -euo pipefail

# shellcheck disable=SC1091
source "#{{ .chezmoi.homeDir }}/.config/chezmoi-corytheboyd/shell.sh"

# shellcheck disable=SC1091
source "$(chezmoi_corytheboyd_path)/shell/lib/install.zsh"
# shellcheck disable=SC1091
source "$(chezmoi_corytheboyd_path)/shell/lib/logger.zsh"

if ! os_is_darwin; then
	log_debug "Not darwin, skipping"
	exit 0
fi

log_info "Bootstrapping darwin..."

log_info "Installing oh-my-zsh..."
install_omz
