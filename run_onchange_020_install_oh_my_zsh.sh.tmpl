#!/usr/bin/env bash

# shellcheck disable=SC1091
{
	source "{{ .chezmoi.homeDir }}/.config/chezmoi-corytheboyd/shell.sh"
	source "$(chezmoi_corytheboyd_path)/shell/lib/logger.zsh"
	source "$(chezmoi_corytheboyd_path)/shell/lib/install.zsh"
}

if has_directory "{{ .chezmoi.homeDir }}/.oh-my-zsh"; then
	log_debug "oh-my-zsh already installed"
	exit 0
fi

log_info "Installing oh-my-zsh..."

if ! has_program zsh; then
	log_info "Missing zsh, installing..."
	if os_is_darwin; then
		brew install zsh
	fi
	if os_is_archlinux; then
		sudo pacman -Sy --noconfirm zsh
	fi
	log_info "Setting default shell to zsh..."
	sudo chsh -s "$(which zsh)" "$(whoami)"
fi

export RUNZSH=no
export KEEP_ZSHRC=yes
export OVERWRITE_CONFIRMATION=no

sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
